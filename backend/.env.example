# ─── Server ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:4200

# ─── Database (Neon PostgreSQL) ─────────────────────────
# Pooled connection (used by the app at runtime)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/imageify?sslmode=require"
# Direct connection (used by Prisma Migrate only)
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/imageify?sslmode=require"

# ─── JWT ────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ─── Hugging Face Inference API ─────────────────────────
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxx
HF_MODEL=stabilityai/stable-diffusion-xl-base-1.0

# ─── Razorpay (Test Mode) ───────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
